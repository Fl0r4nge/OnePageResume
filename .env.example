# ============================================================
# OnePageResume - Docker Compose Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# --- Optional ---

# JWT secrets (auto-generated if not set; tokens will invalidate on restart)
# For production, generate with: openssl rand -hex 32
# JWT_SECRET=
# JWT_REFRESH_SECRET=

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=one_page_resume

# App port (exposed to host)
PORT=3001

# Frontend URL (for CORS, set to your domain in production)
FRONTEND_URL=http://localhost:3001

# Anthropic API key (required for AI compression feature)
ANTHROPIC_API_KEY=
